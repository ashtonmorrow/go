# Copy to .env.local and fill in.

# --- Notion ---
# 1) Go to https://www.notion.so/my-integrations and create a new internal integration.
# 2) Copy the Internal Integration Token. It starts with "ntn_" or "secret_".
# 3) In Notion, open the City Facts database and the Countries database, click the
#    three-dot menu → Connections → add your integration.
NOTION_TOKEN=

# --- Google Maps ---
# 1) Go to https://console.cloud.google.com/ → APIs & Services → Credentials.
# 2) Create an API key. Restrict it by HTTP referrer (add go.mike-lee.me and localhost).
# 3) Enable "Maps JavaScript API".
# Optional: create a Map ID in "Map management" and paste it as NEXT_PUBLIC_GOOGLE_MAPS_ID.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_ID=

# --- Supabase (pins) ---
# The pins table lives in the Stray Supabase project. Public-read via RLS,
# so the publishable/anon key is safe to ship in the browser.
NEXT_PUBLIC_SUPABASE_URL=https://pdjrvlhepiwkshxerkpz.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# --- Revalidation webhook ---
# Any string you want. When triggering /api/revalidate?secret=..., pass this value.
REVALIDATE_SECRET=

# --- OpenAQ ---
# Air quality readings on city pages (PM2.5 + monthly averages from the
# nearest monitoring station within 25 km).
# 1) Sign up at https://explore.openaq.org/register (free).
# 2) Copy the API key from your account page.
# Free tier is 60 req/min, more than enough with the 30-day ISR cache.
# If absent, the EnvironmentalScrubber falls back to weather + daylight only.
OPENAQ_API_KEY=

# --- TransitLand ---
# Public-transit operators for the "Getting around" panel on city pages.
# 1) Sign up at https://www.transit.land/signup (free).
# 2) Copy the API key from your dashboard.
# Free tier is 10k requests/day; with 7-day ISR caching, a few requests
# per city per week is more than enough. If absent, the TransitPanel
# hides itself.
TRANSITLAND_API_KEY=

# --- Translation ---
# Translations for the /languages/[slug] guide pages are generated by
# Gemini through the Stray "generate-stay-review" edge function, using
# STRAY_SUPABASE_SERVICE_ROLE_KEY (already set above for other scripts).
# Run `npm run languages:sync` to (re)generate data/languages.json.

# --- OpenSky (optional) ---
# The live-aircraft panel proxies through /api/sky. Anonymous works but
# is capped at 100 credits/day per server IP — fine for a small atlas,
# marginal under any real traffic. With credentials the cap is 4,000/day.
# Sign up at https://opensky-network.org/login.
#
# Newer accounts (recommended): on the account page, create an API
# client; OpenSky returns a CLIENT_ID + CLIENT_SECRET (OAuth2 client
# credentials). Paste both below.
# OPENSKY_CLIENT_ID=
# OPENSKY_CLIENT_SECRET=
#
# Legacy accounts: if your account predates OAuth2, you may only have a
# username + password (Basic Auth). Use these instead; the proxy picks
# whichever pair is set.
# OPENSKY_USERNAME=
# OPENSKY_PASSWORD=
